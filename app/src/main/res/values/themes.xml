<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema principal con Core Splash Screen API -->
    <style name="Theme.PANGEAapp" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Barra de estado (notificaciones) fija -->
        <item name="android:statusBarColor">#006CBF</item>
        <!-- Íconos claros para buen contraste sobre rojo oscuro -->
        <item name="android:windowLightStatusBar">false</item>
        <!-- Fondo blanco para transición suave post-splash -->
        <item name="android:windowBackground">@android:color/white</item>
    </style>

    <!-- Tema de Splash para cold start optimizado -->
    <style name="Theme.PANGEAapp.Splash" parent="Theme.SplashScreen">
        <!-- Color de fondo del splash - rojo AC1926 -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <!-- Icono central del splash - transparente para que el GIF de Compose sea protagonista -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <!-- Tema post-splash -->
        <item name="postSplashScreenTheme">@style/Theme.PANGEAapp</item>
        <!-- Barra de estado durante splash - mismo color que el fondo -->
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    
</resources>